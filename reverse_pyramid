import java.util.*;
class Reversepyramid
{
	public static void main(String []args)
	{
		Scanner sc=new Scanner(System.in);
		System.out.print("enter any number:");
		int n=sc.nextInt();
		for(int i=1;i<=n;i++)
		{
			for(int space=1;space<i;space++)
			{
				System.out.print(" ");
			}
			for(int j=i;j<=n;j++)
			{
				System.out.print("* ");
			}
			System.out.println(" ");
		}
	}
}
